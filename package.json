{
  "name": "ateliers-bureautique",
  "private": true,
  "description": "Monorepo des ateliers bureautiques Pimms.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "release:all": "if exist \"%LOCALAPPDATA%\\Programs\\Git\\bin\\bash.exe\" (\"%LOCALAPPDATA%\\Programs\\Git\\bin\\bash.exe\" scripts/release-all.sh) else (bash scripts/release-all.sh)",
    "lance": "node scripts/run-release-all.mjs",
    "lance pub": "npm run release:all",
    "word:build:data": "npm --prefix apps/word run build:data",
    "word:sync:app": "npm --prefix apps/word run sync:app",
    "word:repair:encoding": "npm --prefix apps/word run repair:encoding",
    "word:validate:encoding": "npm --prefix apps/word run validate:encoding",
    "word:test": "npm --prefix apps/word test",
    "word:release": "npm --prefix apps/word run release",
    "word:release:all": "npm --prefix apps/word run release:all",
    "excel:build:data": "npm --prefix apps/excel run build:data",
    "excel:sync:app": "npm --prefix apps/excel run sync:app",
    "excel:repair:encoding": "npm --prefix apps/excel run repair:encoding",
    "excel:validate:encoding": "npm --prefix apps/excel run validate:encoding",
    "excel:scrape:data": "npm --prefix apps/excel run scrape:data",
    "excel:revise:data": "npm --prefix apps/excel run revise:data",
    "excel:audit:data": "npm --prefix apps/excel run audit:data",
    "excel:test": "npm --prefix apps/excel test",
    "runtime:validate:word": "node packages/atelier-core/scripts/validate-browser-runtime-sync.mjs --app-root apps/word",
    "runtime:validate:excel": "node packages/atelier-core/scripts/validate-browser-runtime-sync.mjs --app-root apps/excel",
    "runtime:validate": "npm run runtime:validate:word && npm run runtime:validate:excel",
    "excel:release": "npm --prefix apps/excel run release",
    "excel:release:all": "npm --prefix apps/excel run release:all"
  }
}
